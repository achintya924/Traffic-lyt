# ── Railway environment variables ──────────────────────────────────────────────
# Copy these into each Railway service's "Variables" tab.
# Do NOT commit real secrets — this file is documentation only.

# ── API service ─────────────────────────────────────────────────────────────────
# Provided automatically when you attach a Railway PostgreSQL plugin:
DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# Comma-separated list of allowed frontend origins.
# Use * only during initial testing; replace with the real web URL before going live.
CORS_ORIGINS=https://your-web-service.up.railway.app

# Set to true to enable /internal/cache and /internal/metrics endpoints.
DEBUG=false

# ── Web service ──────────────────────────────────────────────────────────────────
# Set this to the public URL of your Railway API service.
# It is baked into the Next.js bundle at build time (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_API_BASE_URL=https://your-api-service.up.railway.app
